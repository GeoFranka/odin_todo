    cursor: pointer;
}

#container {
    height: 100vh;
    display: grid;
    grid-template-columns: clamp(200px, 25vw, 400px) 1fr;
}

#container > * {
    padding: 20px;
}

#sidebar {
    background-color: lightskyblue;
}

.project-btn {
    width: 100%;
    border: none;
    border-radius: 5px;
    padding: 5px 15px;
    margin-bottom: 10px;
    background-color: rgba(250, 250, 250, 0.5);
    font-weight: 500;
    font-size: 1.5rem;
    text-align: left;
}

.project-btn:hover, .project-btn.active {
    background-color: rgba(5, 5, 5, 0.5);
    color: white;
}

#sidebar > .wrapper {
    margin-bottom: 16px;
}

.project-add {
    background-image: url(${___CSS_LOADER_URL_REPLACEMENT_0___});
}

#main {
    background-color: cornsilk;
    overflow: auto;
}

.project-title {
    display: block;
    font-size: 2em;
    margin-block-start: 0;
    margin-block-end: 0.67em;
    margin-inline-start: 0px;
    margin-inline-end: 0px;
    font-weight: bold;
}

.project-form > .save {
    display: block;
    margin: 10px 0;
    height: 48px;
    width: 48px;
}

.wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.project-descr {
    font-style: italic;
}

.todo {
    border: 2px solid gray;
    border-radius: 10px;
    margin-bottom: 10px;
}

.todo-main {
    display: grid;
    grid-template-columns: 24px 3fr 2fr 24px;
    column-gap: 10px;
    align-items: center;
    background-color: gray;
    color: white;
    padding: 3px;
}

.todo-main.low-prio {
    background-color: yellow;
}
.todo-main.medium-prio {
    background-color: orange;
}
.todo-main.high-prio {
    background-color: red;
}

.todo-main.done {
    background-color: green;
}

.todo-detail {
    display: grid;
    grid-template-columns: 3fr 2fr;
    column-gap: 10px;
    row-gap: 3px;
    align-items: center;
    padding: 3px 37px;
}

.icon {
    width: 24px;
    height: 24px;
    padding: 0;
    border: none;
    background-position: center;
    background-repeat: no-repeat;
    background-color: transparent;
}

.icon.undone {
    background-image: url(${___CSS_LOADER_URL_REPLACEMENT_1___});
}

.icon.done {
    background-image: url(${___CSS_LOADER_URL_REPLACEMENT_2___});
}

.partly-done {
    background-image: url(${___CSS_LOADER_URL_REPLACEMENT_3___});
}

.todo-title.done{
    text-decoration: line-through;
    color: lightgray;
}

.due-date.done {
    color: lightgreen;
}

.done-date {
    font-weight: 600;
}

.expand {
    background-image: url(${___CSS_LOADER_URL_REPLACEMENT_4___});
}

.collapse {
    background-image: url(${___CSS_LOADER_URL_REPLACEMENT_5___});
}

.collapsed {
    display: none;
}

.checklist-item {
    display: flex;
    align-items: center;
}

.todo-add {
    background-image: url(${___CSS_LOADER_URL_REPLACEMENT_6___});
}

.checklist-add {
    background-image: url(${___CSS_LOADER_URL_REPLACEMENT_7___});
    align-self: start;
}

.checklist-undone {
    background-image: url(${___CSS_LOADER_URL_REPLACEMENT_8___});
}

.checklist-done {
    background-image: url(${___CSS_LOADER_URL_REPLACEMENT_9___});
}

.save {
    background-image: url(${___CSS_LOADER_URL_REPLACEMENT_10___});
}

.delete {
    background-image: url(${___CSS_LOADER_URL_REPLACEMENT_11___});
    justify-self: end;
}
